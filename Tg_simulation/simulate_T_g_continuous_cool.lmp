units real
atom_style full

read_data /Users/arcadio/lammps_simulation/Tg_simulation/build_pe_melt.data

pair_style lj/cut 14.0
bond_style harmonic
angle_style harmonic
dihedral_style opls
special_bonds lj 0.0 0.0 0.5

# Pair: CH2(1) 和 CH3(2) 的 LJ 参数 (TraPPE-UA)
pair_coeff 1 1 0.0914 3.95     # CH2
pair_coeff 2 2 0.1947 3.75     # CH3

# Bond: C-C 键
bond_coeff 1 450.0 1.54
bond_coeff 2 450.0 1.54

# Angle: C-C-C 角
angle_coeff 1 62.5 114.0
angle_coeff 2 62.5 114.0

# Dihedral: OPLS 参数 (TraPPE-UA)
dihedral_coeff 1 1.411 -0.271 3.145 0.0   # CH2-CH2-CH2-CH2
dihedral_coeff 2 1.411 -0.271 3.145 0.0   # 链端

# 压缩阶段: 高压 NPT 压缩盒子至合理密度
fix 1 all npt temp 500 500 100 iso 100 100 1000
run 50000

# 弛豫阶段: 常压平衡
fix 1 all npt temp 500 500 100 iso 1 1 1000
run 100000

# ---------------------------------------------------------------
# 连续降温阶段: 从 500K 匀速降至 100K
# 使用 fix npt 的内置斜坡功能: temp Tstart Tstop
# LAMMPS 会在 run 过程中线性插值目标温度
#
# 有效降温速率 ≈ (500-100)/[总步数 × dt]
#   dt = 1 fs (real units), 总步数 1,000,000 → 400 K/ns
#   如果觉得太快, 增大总步数即可 (如 5,000,000 → 80 K/ns)
# ---------------------------------------------------------------
reset_timestep 0

thermo_style custom step temp density vol
thermo 1000

# 连续降温: 从 500K 到 100K, NPT (1 atm)
unfix 1
fix 1 all npt temp 500 150 100 iso 1 1 1000

# 每 5000 步保存一次轨迹 (可选, 用于可视化)
dump 1 all custom 5000 dump_continuous_cool.lammpstrj id mol type x y z

run 1000000

write_data final_continuous.data