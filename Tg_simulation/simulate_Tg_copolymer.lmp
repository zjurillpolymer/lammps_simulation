# Tg simulation for PE-co-PP random copolymer (TraPPE-UA)
# Continuous cooling: 500K → 100K at ~400 K/ns
# Works with EMC-generated .data and .params files
#
# Usage:
#   lmp -in simulate_Tg_copolymer.lmp \
#       -var DATA build_pe_pp_copolymer.data \
#       -var PARAMS build_pe_pp_copolymer.params

variable data    index /Users/arcadio/lammps_simulation/Tg_simulation/pp50.data
variable params  index /Users/arcadio/lammps_simulation/Tg_simulation/pp50.params
variable project index pe_pp_tg
variable cutoff  index 14

log		log_${project}.lammps

units		real
atom_style	full
boundary	p p p

# Force field styles (needed before read_data)
pair_style	lj/cut ${cutoff}
bond_style	harmonic
angle_style	harmonic
dihedral_style	multi/harmonic
special_bonds	lj 0 0 0 coul 0 0 0.5
pair_modify	mix arithmetic tail yes

# Read structure
read_data	${data}

# Include force field coefficients from EMC
include		${params}

# ─── Compress & equilibrate at 500K ───
fix 1 all npt temp 500 500 100 iso 100 100 1000
run 50000

fix 1 all npt temp 500 500 100 iso 1 1 1000
run 100000

# ─── Continuous Tg cooling ───
reset_timestep 0
thermo_style custom step temp density vol
thermo 1000

unfix 1
fix 1 all npt temp 500 150 100 iso 1 1 1000
dump 1 all custom 5000 ${project}_dump.lammpstrj id mol type x y z
run 100000

write_data ${project}_final.data
